# ─── Server ───────────────────────────────────────────────────────────────────

# Solana network: mainnet-beta | devnet | localnet
NETWORK=devnet

# Custom RPC endpoint (optional — falls back to public node)
RPC_URL=https://api.devnet.solana.com

# HMAC secret that binds payment challenges to this server instance.
# Generate with: openssl rand -hex 32
MPP_SECRET=replace_with_32_byte_hex_secret

# Base58 address that receives payments
RECIPIENT_ADDRESS=YourBase58RecipientAddressHere

# Base58-encoded private key of the fee-payer wallet (server sponsors tx fees).
# Generate a fresh keypair with: npm run keygen
FEE_PAYER_PRIVATE_KEY=YourBase58PrivateKeyHere

# Server port
PORT=3000

# ─── Client ───────────────────────────────────────────────────────────────────

# Base58-encoded private key of the paying wallet
CLIENT_PRIVATE_KEY=YourBase58ClientPrivateKeyHere

# API server base URL
API_BASE_URL=http://localhost:3000
